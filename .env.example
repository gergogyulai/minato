# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of your deployment (used for auth redirects)
# BETTER_AUTH_URL=https://minato.example.com

# Allowed CORS origin if frontend is on a different domain
# CORS_ORIGIN=https://minato.example.com

# PostgreSQL connection string
DATABASE_URL=postgresql://minato_user:minato_password@localhost:5432/minato

# Redis connection string
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
# Generate with: openssl rand -hex 32
MEILISEARCH_MASTER_KEY=

# TMDB Read Access Token — https://developer.themoviedb.org/docs/getting-started
TMDB_READ_ACCESS_TOKEN=
