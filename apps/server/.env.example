# --- Auth Config ---
BETTER_AUTH_SECRET=your_32_character_secret_here
# Optional: explicit external URL/origin override (usually not needed in Docker)
# BETTER_AUTH_URL=https://your-domain.example
# CORS_ORIGIN=https://your-domain.example

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_MASTER_KEY=your_meilisearch_master_key_here

# --- App Specific ---
MINATO_SEARCH_ENGINE_PROFILE=freshness
MEDIA_ROOT=/data/media

# --- Node ---
NODE_ENV=development
